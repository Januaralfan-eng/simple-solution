APP_NAME="Creative Agency"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=creative_agency
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
CACHE_PREFIX=agency_

QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp Integration
WHATSAPP_NUMBER=6281234567890
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Agency Config
AGENCY_NAME="Creative Agency"
AGENCY_TAGLINE="We Build Digital Experiences"
AGENCY_EMAIL=hello@youragency.com
AGENCY_PHONE=+62 812 3456 7890
AGENCY_ADDRESS="Jl. Raya No. 1, Jakarta"

# Google Analytics
GA_MEASUREMENT_ID=
GA_VIEW_ID=

# SEO
SEO_DEFAULT_TITLE="Creative Agency - We Build Digital Experiences"
SEO_DEFAULT_DESCRIPTION="Premium creative tech agency specializing in web development, UI/UX design, and digital strategy."

# Kamus.zasha.online Error Logging
KAMUS_LOGGING_ENABLED=true
KAMUS_API_KEY=

# Image Optimization
IMAGE_MAX_WIDTH=2400
IMAGE_QUALITY=85
