{
  "$comment": "Schema of editable text fields. Each field maps to a CSS selector inside preview-home.html. type=text|textarea. Selectors must be unique-targeting.",
  "sections": [
    {
      "id": "brand",
      "title": "Brand & SEO (global)",
      "fields": [
        {
          "key": "brand.name",
          "label": "Nama brand (sync di navbar, footer, copyright)",
          "type": "text",
          "selector": "[data-brand-name]",
          "multi": true
        },
        {
          "key": "brand.logo",
          "label": "Logo brand (upload PNG/JPG/SVG, max 2 MB). Kosongkan untuk pakai huruf fallback.",
          "type": "image",
          "selector": "[data-brand-logo]",
          "attribute": "src",
          "multi": true,
          "uploadSlot": "logo"
        },
        {
          "key": "brand.letter",
          "label": "Huruf logo (fallback kalau logo image kosong)",
          "type": "text",
          "selector": "[data-brand-letter]",
          "multi": true
        },
        {
          "key": "page.title",
          "label": "Page title (tag <title>, untuk SEO + browser tab)",
          "type": "text",
          "selector": "head > title"
        }
      ]
    },
    {
      "id": "hero",
      "title": "Hero (atas halaman)",
      "fields": [
        {
          "key": "hero.badge",
          "label": "Badge \"Tersedia untuk proyek baru\"",
          "type": "text",
          "selector": "main > section:first-of-type .inline-flex.items-center.gap-2.px-4"
        },
        {
          "key": "hero.title",
          "label": "Judul utama (boleh HTML, gunakan <br>)",
          "type": "textarea",
          "selector": "main > section:first-of-type h1",
          "html": true
        },
        {
          "key": "hero.subtitle",
          "label": "Sub-judul / paragraf utama",
          "type": "textarea",
          "selector": "main > section:first-of-type p.section-subtitle"
        },
        {
          "key": "hero.cta-primary",
          "label": "Tombol utama (kiri)",
          "type": "text",
          "selector": "main > section:first-of-type a.btn-primary",
          "textOnly": true
        },
        {
          "key": "hero.cta-secondary",
          "label": "Tombol sekunder (kanan)",
          "type": "text",
          "selector": "main > section:first-of-type a.btn-secondary",
          "textOnly": true
        },
        {
          "key": "hero.stat1-num",
          "label": "Statistik 1 — angka",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(1) > div:first-child"
        },
        {
          "key": "hero.stat1-label",
          "label": "Statistik 1 — label",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(1) > div:last-child"
        },
        {
          "key": "hero.stat2-num",
          "label": "Statistik 2 — angka",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(2) > div:first-child"
        },
        {
          "key": "hero.stat2-label",
          "label": "Statistik 2 — label",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(2) > div:last-child"
        },
        {
          "key": "hero.stat3-num",
          "label": "Statistik 3 — angka",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(3) > div:first-child"
        },
        {
          "key": "hero.stat3-label",
          "label": "Statistik 3 — label",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(3) > div:last-child"
        },
        {
          "key": "hero.stat4-num",
          "label": "Statistik 4 — angka",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(4) > div:first-child"
        },
        {
          "key": "hero.stat4-label",
          "label": "Statistik 4 — label",
          "type": "text",
          "selector": "main > section:first-of-type .text-center:nth-child(4) > div:last-child"
        }
      ]
    },
    {
      "id": "services",
      "title": "Layanan",
      "fields": [
        {
          "key": "services.eyebrow",
          "label": "Label kecil \"Apa yang kami kerjakan\"",
          "type": "text",
          "selector": "#services .section-label",
          "textOnly": true
        },
        {
          "key": "services.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#services h2.section-title"
        },
        {
          "key": "services.subtitle",
          "label": "Sub-judul",
          "type": "textarea",
          "selector": "#services p.section-subtitle"
        }
      ],
      "listConfig": {
        "container": "#services .grid",
        "itemSelector": "div.card",
        "min": 1,
        "max": 12,
        "label": "Layanan"
      },
      "itemFields": [
        {
          "key": "title",
          "label": "Judul",
          "type": "text",
          "scope": "h3"
        },
        {
          "key": "desc",
          "label": "Deskripsi",
          "type": "textarea",
          "scope": "p"
        },
        {
          "key": "link",
          "label": "Link \"Selengkapnya\" (URL)",
          "type": "text",
          "scope": "[data-service-link]",
          "attribute": "href"
        }
      ]
    },
    {
      "id": "portfolio",
      "title": "Portfolio / Proyek Pilihan (4 kartu)",
      "fields": [
        {
          "key": "portfolio.eyebrow",
          "label": "Label kecil \"Karya kami\"",
          "type": "text",
          "selector": "#portfolio .section-label",
          "textOnly": true
        },
        {
          "key": "portfolio.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#portfolio h2.section-title"
        }
      ],
      "listConfig": {
        "container": "#portfolio .grid",
        "itemSelector": "article",
        "min": 1,
        "max": 12,
        "label": "Proyek"
      },
      "itemFields": [
        {
          "key": "cat1",
          "label": "Kategori 1 (badge)",
          "type": "text",
          "scope": ".p-6 > div:first-child > span:nth-of-type(1)"
        },
        {
          "key": "cat2",
          "label": "Kategori 2 (badge)",
          "type": "text",
          "scope": ".p-6 > div:first-child > span:nth-of-type(2)"
        },
        {
          "key": "cover",
          "label": "Huruf cover (fallback)",
          "type": "text",
          "scope": "span.text-6xl"
        },
        {
          "key": "image",
          "label": "Upload foto cover",
          "type": "image",
          "scope": "[data-portfolio-img]",
          "attribute": "src",
          "uploadSlot": "portfolio"
        },
        {
          "key": "link",
          "label": "Link proyek (URL)",
          "type": "text",
          "scope": "[data-portfolio-link]",
          "attribute": "href"
        },
        {
          "key": "title",
          "label": "Judul proyek",
          "type": "text",
          "scope": ".p-6 > h3"
        },
        {
          "key": "desc",
          "label": "Deskripsi proyek",
          "type": "textarea",
          "scope": ".p-6 > p"
        }
      ]
    },
    {
      "id": "about",
      "title": "Cara Kerja Kami (Proses)",
      "fields": [
        {
          "key": "about.eyebrow",
          "label": "Label kecil \"Cara kerja kami\"",
          "type": "text",
          "selector": "#about .section-label",
          "textOnly": true
        },
        {
          "key": "about.title",
          "label": "Judul section (boleh <br>)",
          "type": "textarea",
          "selector": "#about h2.section-title",
          "html": true
        },
        {
          "key": "about.subtitle",
          "label": "Sub-judul",
          "type": "textarea",
          "selector": "#about p.section-subtitle"
        },
        {
          "key": "about.step1.title",
          "label": "Step 1 — judul",
          "type": "text",
          "selector": "#about .space-y-6 > div:nth-child(1) h3"
        },
        {
          "key": "about.step1.desc",
          "label": "Step 1 — deskripsi",
          "type": "textarea",
          "selector": "#about .space-y-6 > div:nth-child(1) p"
        },
        {
          "key": "about.step2.title",
          "label": "Step 2 — judul",
          "type": "text",
          "selector": "#about .space-y-6 > div:nth-child(2) h3"
        },
        {
          "key": "about.step2.desc",
          "label": "Step 2 — deskripsi",
          "type": "textarea",
          "selector": "#about .space-y-6 > div:nth-child(2) p"
        },
        {
          "key": "about.step3.title",
          "label": "Step 3 — judul",
          "type": "text",
          "selector": "#about .space-y-6 > div:nth-child(3) h3"
        },
        {
          "key": "about.step3.desc",
          "label": "Step 3 — deskripsi",
          "type": "textarea",
          "selector": "#about .space-y-6 > div:nth-child(3) p"
        },
        {
          "key": "about.step4.title",
          "label": "Step 4 — judul",
          "type": "text",
          "selector": "#about .space-y-6 > div:nth-child(4) h3"
        },
        {
          "key": "about.step4.desc",
          "label": "Step 4 — deskripsi",
          "type": "textarea",
          "selector": "#about .space-y-6 > div:nth-child(4) p"
        },
        {
          "key": "about.stat-number",
          "label": "Visual stat — angka besar (mis. \"4 thn\")",
          "type": "text",
          "selector": "[data-about-stat-number]"
        },
        {
          "key": "about.stat-label",
          "label": "Visual stat — label di bawah angka",
          "type": "text",
          "selector": "[data-about-stat-label]"
        },
        {
          "key": "about.stat-badge",
          "label": "Visual stat — badge floating kanan-bawah",
          "type": "text",
          "selector": "[data-about-stat-badge]"
        }
      ]
    },
    {
      "id": "team",
      "title": "Tim Kami",
      "fields": [
        {
          "key": "team.eyebrow",
          "label": "Label kecil \"Tim kami\"",
          "type": "text",
          "selector": "#team .section-label",
          "textOnly": true
        },
        {
          "key": "team.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#team h2.section-title"
        },
        {
          "key": "team.subtitle",
          "label": "Sub-judul",
          "type": "textarea",
          "selector": "#team p.section-subtitle"
        }
      ],
      "listConfig": {
        "container": "#team .grid",
        "itemSelector": "article",
        "min": 1,
        "max": 12,
        "label": "Anggota"
      },
      "itemFields": [
        {
          "key": "name",
          "label": "Nama",
          "type": "text",
          "scope": "h3"
        },
        {
          "key": "role",
          "label": "Jabatan / role",
          "type": "text",
          "scope": "p.text-xs"
        },
        {
          "key": "is_founder",
          "label": "Founder? (isi \"true\" untuk tampilkan badge ★ Founder, kosongkan = bukan)",
          "type": "text",
          "scope": "",
          "attribute": "data-team-founder"
        },
        {
          "key": "initial",
          "label": "Inisial (2 huruf avatar)",
          "type": "text",
          "scope": "[data-team-initial]"
        },
        {
          "key": "image",
          "label": "Upload foto avatar (PNG/JPG, max 2 MB) — opsional, fallback ke inisial",
          "type": "image",
          "scope": "[data-team-avatar]",
          "attribute": "src",
          "uploadSlot": "team"
        },
        {
          "key": "bio",
          "label": "Bio",
          "type": "textarea",
          "scope": "p.text-sm"
        },
        {
          "key": "link",
          "label": "Link portofolio (URL)",
          "type": "text",
          "scope": "[data-team-link]",
          "attribute": "href"
        }
      ]
    },
    {
      "id": "blog",
      "title": "Blog / Wawasan (3 artikel)",
      "fields": [
        {
          "key": "blog.eyebrow",
          "label": "Label kecil \"Insight\"",
          "type": "text",
          "selector": "#blog .section-label",
          "textOnly": true
        },
        {
          "key": "blog.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#blog h2.section-title"
        }
      ],
      "listConfig": {
        "container": "#blog .grid",
        "itemSelector": "article",
        "min": 1,
        "max": 12,
        "label": "Artikel"
      },
      "itemFields": [
        {
          "key": "cat",
          "label": "Kategori",
          "type": "text",
          "scope": ".badge"
        },
        {
          "key": "date",
          "label": "Tanggal",
          "type": "text",
          "scope": "[data-blog-date]"
        },
        {
          "key": "title",
          "label": "Judul",
          "type": "text",
          "scope": "h3"
        },
        {
          "key": "excerpt",
          "label": "Ringkasan",
          "type": "textarea",
          "scope": ".p-6 > p"
        },
        {
          "key": "link",
          "label": "Link \"Baca artikel\" (URL)",
          "type": "text",
          "scope": "[data-blog-link]",
          "attribute": "href"
        }
      ]
    },
    {
      "id": "testimonials",
      "title": "Testimoni Klien",
      "fields": [
        {
          "key": "testimonials.eyebrow",
          "label": "Label kecil \"Kata klien kami\"",
          "type": "text",
          "selector": "#testimonials .section-label",
          "textOnly": true
        },
        {
          "key": "testimonials.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#testimonials h2.section-title"
        },
        {
          "key": "testimonials.subtitle",
          "label": "Sub-judul",
          "type": "textarea",
          "selector": "#testimonials p.section-subtitle"
        }
      ],
      "listConfig": {
        "container": "#testimonials .grid",
        "itemSelector": "article",
        "min": 1,
        "max": 12,
        "label": "Testimoni"
      },
      "itemFields": [
        {
          "key": "quote",
          "label": "Kutipan testimoni",
          "type": "textarea",
          "scope": "p.flex-grow"
        },
        {
          "key": "name",
          "label": "Nama (PIC)",
          "type": "text",
          "scope": "h3"
        },
        {
          "key": "business",
          "label": "Bisnis · Kota",
          "type": "text",
          "scope": "p.text-xs"
        },
        {
          "key": "badge",
          "label": "Badge layanan (mis. \"Web Portofolio\")",
          "type": "text",
          "scope": "span"
        }
      ]
    },
    {
      "id": "pricing",
      "title": "Harga (Pricing)",
      "fields": [
        {
          "key": "pricing.eyebrow",
          "label": "Label kecil \"Harga\"",
          "type": "text",
          "selector": "#pricing .section-label",
          "textOnly": true
        },
        {
          "key": "pricing.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#pricing h2.section-title"
        },
        {
          "key": "pricing.subtitle",
          "label": "Sub-judul",
          "type": "textarea",
          "selector": "#pricing p.section-subtitle"
        }
      ],
      "listConfig": {
        "container": "#pricing .grid",
        "itemSelector": "div",
        "min": 1,
        "max": 6,
        "label": "Paket"
      },
      "itemFields": [
        {
          "key": "name",
          "label": "Nama paket",
          "type": "text",
          "scope": "h3"
        },
        {
          "key": "desc",
          "label": "Deskripsi paket",
          "type": "text",
          "scope": ".mb-5 > p"
        },
        {
          "key": "price",
          "label": "Harga (teks)",
          "type": "text",
          "scope": ".mb-6 > span:first-child"
        },
        {
          "key": "price-suffix",
          "label": "Suffix harga (mis. \"/ proyek\")",
          "type": "text",
          "scope": ".mb-6 > span:last-child"
        },
        {
          "key": "feature1",
          "label": "Fitur 1",
          "type": "text",
          "scope": "ul > li:nth-of-type(1)",
          "textOnly": true
        },
        {
          "key": "feature2",
          "label": "Fitur 2",
          "type": "text",
          "scope": "ul > li:nth-of-type(2)",
          "textOnly": true
        },
        {
          "key": "feature3",
          "label": "Fitur 3",
          "type": "text",
          "scope": "ul > li:nth-of-type(3)",
          "textOnly": true
        },
        {
          "key": "feature4",
          "label": "Fitur 4",
          "type": "text",
          "scope": "ul > li:nth-of-type(4)",
          "textOnly": true
        },
        {
          "key": "feature5",
          "label": "Fitur 5 (opsional, kosongkan kalau tidak ada)",
          "type": "text",
          "scope": "ul > li:nth-of-type(5)",
          "textOnly": true
        },
        {
          "key": "cta",
          "label": "Tombol CTA teks (mis. \"Mulai Sekarang\")",
          "type": "text",
          "scope": "a.block.text-center",
          "textOnly": true
        },
        {
          "key": "cta-link",
          "label": "Tombol CTA link (URL)",
          "type": "text",
          "scope": "a.block.text-center",
          "attribute": "href"
        }
      ]
    },
    {
      "id": "faq",
      "title": "FAQ",
      "fields": [
        {
          "key": "faq.title",
          "label": "Judul section",
          "type": "text",
          "selector": "#faq h2.section-title"
        }
      ],
      "listConfig": {
        "container": "#faq .space-y-2",
        "itemSelector": "div.card",
        "min": 1,
        "max": 20,
        "label": "Pertanyaan"
      },
      "itemFields": [
        {
          "key": "q",
          "label": "Pertanyaan",
          "type": "text",
          "scope": "button > span:first-child"
        },
        {
          "key": "a",
          "label": "Jawaban",
          "type": "textarea",
          "scope": "> div:last-child"
        }
      ]
    },
    {
      "id": "cta",
      "title": "CTA Akhir",
      "fields": [
        {
          "key": "cta.eyebrow",
          "label": "Label \"Siap mulai?\"",
